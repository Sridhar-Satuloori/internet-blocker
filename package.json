{
  "name": "internet-blocker",
  "version": "1.0.0-alpha.2",
  "description": "Block internet, websites, apps, and games on Windows and macOS — focus timer, daily schedule, site packs (YouTube, TikTok), firewall and hosts blocking",
  "homepage": "https://sridhar-satuloori.github.io/internet-blocker/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sridhar-Satuloori/internet-blocker.git"
  },
  "bugs": {
    "url": "https://github.com/Sridhar-Satuloori/internet-blocker/issues"
  },
  "main": "main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-electron.js --enable-logging",
    "generate-icons": "node scripts/generate-icons.js",
    "build": "node scripts/build-release.js",
    "build:win": "node scripts/build-release.js win32 x64",
    "build:mac": "node scripts/build-release.js darwin arm64",
    "build:mac-intel": "node scripts/build-release.js darwin x64"
  },
  "keywords": [
    "internet-blocker",
    "website-blocker",
    "block-youtube",
    "block-tiktok",
    "focus-app",
    "productivity",
    "parental-control",
    "firewall",
    "hosts-file",
    "dns-blocking",
    "game-blocker",
    "app-blocker",
    "focus-timer",
    "distraction-blocker",
    "electron",
    "windows",
    "macos"
  ],
  "author": "Sridhar Satuloori (https://github.com/Sridhar-Satuloori)",
  "license": "MIT",
  "build": {
    "appId": "com.internetblocker.app",
    "mac": {
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "Internet Blocker uses your location to display the name of your Wi-Fi network in Network Speed tests."
      }
    }
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "electron": "^35.0.0"
  }
}
